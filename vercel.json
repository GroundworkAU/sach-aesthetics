{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ],
  "redirects": [
    { "source": "/pages/treatments", "destination": "/treatments.html", "permanent": true },
    { "source": "/pages/microneedling", "destination": "/microneedling.html", "permanent": true },
    { "source": "/pages/facial-treatments", "destination": "/facial-treatments.html", "permanent": true },
    { "source": "/pages/chemical-peels", "destination": "/chemical-peels.html", "permanent": true },
    { "source": "/pages/lashes-brows", "destination": "/lashes-brows.html", "permanent": true },
    { "source": "/pages/contact", "destination": "/contact.html", "permanent": true },
    { "source": "/pages/location", "destination": "/location.html", "permanent": true }
  ]
}
