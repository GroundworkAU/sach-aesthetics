{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/img/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/(css|js)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/pages/treatments",
      "destination": "/treatments",
      "permanent": true
    },
    {
      "source": "/pages/microneedling",
      "destination": "/microneedling",
      "permanent": true
    },
    {
      "source": "/pages/facial-treatments",
      "destination": "/facial-treatments",
      "permanent": true
    },
    {
      "source": "/pages/chemical-peels",
      "destination": "/chemical-peels",
      "permanent": true
    },
    {
      "source": "/pages/lashes-brows",
      "destination": "/lashes-brows",
      "permanent": true
    },
    {
      "source": "/pages/contact",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/pages/location",
      "destination": "/location",
      "permanent": true
    }
  ]
}
